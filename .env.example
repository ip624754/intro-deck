TELEGRAM_BOT_TOKEN=replace_me
TELEGRAM_BOT_USERNAME=rollduelbot
PUBLIC_SITE_URL=https://duel-bot.vercel.app
CRYPTO_PAY_API_TOKEN=replace_me
ADMIN_IDS=123456789

# Database
DATABASE_BACKEND=postgres
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/roll_duel
DATABASE_FILE=dice_game.db

# Delivery/runtime
TELEGRAM_DELIVERY_MODE=webhook
APP_BASE_URL=https://your-domain.example
APP_HOST=0.0.0.0
PORT=8080
TELEGRAM_WEBHOOK_PATH=/webhook/telegram
CRYPTOPAY_WEBHOOK_PATH=/webhook/cryptopay
TELEGRAM_WEBHOOK_SECRET=replace_me_strong_secret
ENABLE_INVOICE_POLLING=0
# Legacy fallback only. Keep disabled in the normal webhook baseline.

# Classic bot surface
SUPPORT_TELEGRAM_HANDLE=@rollduelbot
SUPPORT_TON_ADDRESS=
# Telegram group ID for operator support chat (e.g. -1001234567890)
# Add the bot to this group as admin, then paste its ID here
SUPPORT_CHAT_ID=
# Legacy DurovCube handles are ignored at runtime and fall back to @rollduelbot.

# Official player community surfaces (STEP-COMMUNITY-SURFACES-001)
COMMUNITY_OFFICIAL_CHANNEL_URL=https://t.me/RollDuelOfficial
COMMUNITY_CHAT_URL=https://t.me/rollduelchat
# Primary unverified-user entry: Shieldy CAPTCHA is posted in Start Here / Rules.
COMMUNITY_ENTRY_URL=https://t.me/rollduelchat/1
COMMUNITY_RULES_TOPIC_URL=https://t.me/rollduelchat/1
COMMUNITY_OPEN_DUELS_EN_URL=https://t.me/rollduelchat/35
COMMUNITY_OPEN_DUELS_RU_URL=https://t.me/rollduelchat/37
COMMUNITY_CHAT_EN_URL=https://t.me/rollduelchat/39
COMMUNITY_CHAT_RU_URL=https://t.me/rollduelchat/41
COMMUNITY_WINS_URL=https://t.me/rollduelchat/43
COMMUNITY_SUPPORT_URL=https://t.me/rollduelchat/45
COMMUNITY_FEEDBACK_URL=https://t.me/rollduelchat/47
# Telegram delivery retries before the feed row is surfaced for operator recovery
COMMUNITY_DUEL_FEED_MAX_ATTEMPTS=3

# Runtime tuning
# Duel timers are fixed product contracts in services/duel_timeout_policy.py
# Public/private waiting: 900s; Quick: 30s; Demo: 600s; active roll: 60s; reminder: 30s.
# Legacy WAITING_DUEL_TIMEOUT_SECONDS / ACTIVE_DUEL_TIMEOUT_SECONDS env overrides are ignored.
RECONCILIATION_INTERVAL_SECONDS=20
ADMIN_BROADCAST_TICK_SECONDS=15
ADMIN_BROADCAST_BATCH_SIZE=25
LOG_LEVEL=INFO

# Operator web UI
ADMIN_WEB_USERNAME=admin
ADMIN_WEB_PASSWORD=replace_me
ADMIN_WEB_PREFIX=/admin

# Product switches
# Optional at boot; defaults are seeded into platform_settings

# Mini App (frozen / dormant by default)
MINIAPP_RUNTIME_ENABLED=0
MINIAPP_PREFIX=/app
MINIAPP_API_PREFIX=/api/miniapp
MINIAPP_INIT_MAX_AGE_SECONDS=86400
MINIAPP_SESSION_TTL_SECONDS=86400
MINIAPP_SMOKE_CAPTURE_ENABLED=1

# ──────────────────────────────────────────────────────────────
# TON CONNECT
# ──────────────────────────────────────────────────────────────
# Public URL вашего приложения (Railway / VPS). Используется для
# формирования manifest URL и deep-link в Tonkeeper.
APP_BASE_URL=https://your-app.up.railway.app

# Полный URL до tonconnect-manifest.json (если отличается от APP_BASE_URL/tonconnect-manifest.json)
TON_CONNECT_MANIFEST_URL=

# Путь для webhook от Tonkeeper (POST <APP_BASE_URL><TONCONNECT_WEBHOOK_PATH>?user_id=...)
TONCONNECT_WEBHOOK_PATH=/webhook/tonconnect

# ──────────────────────────────────────────────────────────────
# TON API (TonAPI.io — для балансов, транзакций, Jetton)
# ──────────────────────────────────────────────────────────────
# Бесплатный ключ: https://tonconsole.com
TON_API_KEY=

# Legacy only: arbitrary Jetton deposits are hard-disabled by
# STEP-JETTON-DEPOSITS-DISABLE-001. This variable is ignored and must not
# be configured unless a future, separately reviewed HEAVY STEP reintroduces
# asset-identified Jetton support.
# JETTON_DEPOSIT_ADDRESS=

# ──────────────────────────────────────────────────────────────
# МОНИТОРИНГ
# ──────────────────────────────────────────────────────────────
# Путь health-check endpoint (по умолчанию /healthz)
HEALTH_PATH=/healthz

# Shared inline duel-card lifecycle (STEP-SHARED-DUEL-LIVE-STATUS-AND-CONVERSION-007)
# APP_BASE_URL must be a public HTTPS URL for branded /share/... previews (STEP-SHARED-DUEL-BRANDED-PREVIEW-008).
# Optional defaults; BotFather inline feedback must also be enabled for chosen_inline_result delivery.
SHARED_INLINE_BINDING_TTL_DAYS=14
SHARED_INLINE_MAX_EDIT_ATTEMPTS=5

# Telegram Community / Bot API 10.2 ephemeral group UX (STEP-009)
# Fail-closed and disabled by default. Allowlist accepts numeric chat IDs or
# public usernames (e.g. @rollduelchat), comma-separated.
TELEGRAM_EPHEMERAL_GROUP_UX_ENABLED=0
TELEGRAM_EPHEMERAL_GROUP_ALLOWLIST=@rollduelchat
# Optional self-hosted/local Bot API endpoint. Keep official endpoint by default.
TELEGRAM_BOT_API_BASE_URL=https://api.telegram.org
