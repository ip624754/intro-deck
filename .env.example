# Intro Deck — local/development environment template
# Never commit real secrets. Vercel Production values must be configured server-side.

NODE_ENV=development
APP_BASE_URL=http://localhost:3000
RELEASE_ARTIFACT_SHA=

# Telegram
TELEGRAM_BOT_TOKEN=replace_me
TELEGRAM_BOT_USERNAME=introdeckbot
TELEGRAM_WEBHOOK_SECRET=replace_me_with_letters_numbers_underscore_or_dash
INVITE_PHOTO_FILE_ID=
TELEGRAM_UPDATE_DEDUPE_TTL_SECONDS=86400
TELEGRAM_ACTION_THROTTLE_SECONDS=3

# Operators — comma-separated Telegram user IDs
ADMIN_CHAT_ID=
TG_OPERATOR_IDS=
OPERATOR_TELEGRAM_USER_IDS=

# PostgreSQL / Neon
DATABASE_URL=postgresql://user:password@host/neondb?sslmode=require
DATABASE_SSLMODE=require

# LinkedIn base OIDC identity connection
LINKEDIN_CLIENT_ID=replace_me
LINKEDIN_CLIENT_SECRET=replace_me
LINKEDIN_REDIRECT_URI=http://localhost:3000/api/oauth/callback/linkedin
LINKEDIN_SCOPES=openid profile email
LINKEDIN_STATE_SECRET=replace_me_with_letters_numbers_underscore_or_dash
LINKEDIN_OIDC_DISCOVERY_URL=https://www.linkedin.com/oauth/.well-known/openid-configuration
LINKEDIN_STATE_TTL_SECONDS=600
LINKEDIN_JWKS_CACHE_TTL_SECONDS=3600

# Verified on LinkedIn — optional, fail-safe integration
# off | development | lite
LINKEDIN_VERIFIED_MODE=off
LINKEDIN_VERIFIED_SCOPES=r_profile_basicinfo r_verify
LINKEDIN_VERIFIED_IDENTITY_API_VERSION=202510.03
LINKEDIN_VERIFIED_REPORT_API_VERSION=202510
LINKEDIN_VERIFIED_API_TIMEOUT_MS=8000
LINKEDIN_VERIFIED_PUBLIC_BADGES_ENABLED=0
LINKEDIN_VERIFIED_PUBLIC_BADGE_MAX_AGE_DAYS=30

# Share on LinkedIn — explicit one-post authorization only
# off | live
LINKEDIN_SHARE_MODE=off
LINKEDIN_SHARE_SCOPES=w_member_social
LINKEDIN_SHARE_POSTS_API_VERSION=202606
LINKEDIN_SHARE_API_TIMEOUT_MS=8000
LINKEDIN_SHARE_INTENT_TTL_SECONDS=900
LINKEDIN_SHARE_CLAIM_TIMEOUT_SECONDS=300
LINKEDIN_SHARE_VISIBILITY=PUBLIC

# Telegram Stars pricing and contact-contract controls
CONTACT_UNLOCK_PRICE_STARS=75
DM_OPEN_PRICE_STARS=100
PRO_MONTHLY_PRICE_STARS=149
PRO_MONTHLY_DURATION_DAYS=30
PRO_OUTREACH_DAILY_LIMIT=10
CONTACT_REQUEST_RETRY_COOLDOWN_DAYS=30
PAYMENT_CHECKOUT_AUTH_TTL_MINUTES=30
PAYMENT_CHECKOUT_RETRY_LOCK_SECONDS=1800

# Notification receipts, retry, and operator diagnostics
CRON_SECRET=replace_me_with_letters_numbers_underscore_or_dash
NOTIFICATION_RETRY_SECRET=replace_me_with_letters_numbers_underscore_or_dash
NOTIFICATION_OPS_SECRET=replace_me_with_letters_numbers_underscore_or_dash
NOTIFICATION_RETRY_DELAY_SECONDS=300
NOTIFICATION_RETRY_BATCH_SIZE=10
NOTIFICATION_RETRY_CLAIM_TIMEOUT_SECONDS=60
NOTIFICATION_MAX_ATTEMPTS=3
NOTIFICATION_RECEIPT_DIAGNOSTICS_LIMIT=20

# AI/news drafts — source evidence + explicit LinkedIn approval
# off | operator | pro
AI_NEWS_DRAFT_MODE=off
# operator_acceptance | limited_pro | live
AI_NEWS_ROLLOUT_STAGE=operator_acceptance

# newsdata_only | multi_source
# Keep newsdata_only until migration 033 is applied and operator acceptance begins.
AI_NEWS_SOURCE_MODE=newsdata_only
AI_NEWS_ENABLED_PROVIDERS=rss,hacker_news,github_releases,newsdata
AI_NEWS_PROVIDER_MAX_ARTICLES=4
AI_NEWS_RSS_TIMEOUT_MS=7000
AI_NEWS_RSS_MAX_FEEDS_PER_SEARCH=2
AI_NEWS_HN_TIMEOUT_MS=7000
AI_NEWS_HN_SCAN_LIMIT=12
AI_NEWS_HN_MIN_SCORE=10
AI_NEWS_GITHUB_TIMEOUT_MS=8000
AI_NEWS_GITHUB_MAX_REPOS_PER_SEARCH=2
# Optional. Public release reads work without authentication, but a token raises GitHub rate limits.
GITHUB_API_TOKEN=

NEWSDATA_API_KEY=
NEWSDATA_BASE_URL=https://newsdata.io/api/1/
NEWSDATA_API_TIMEOUT_MS=8000
# Optional unit-economics estimate. Keep 0 when current trusted pricing is unknown.
NEWSDATA_REQUEST_COST_USD=0

OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com
OPENAI_DRAFT_MODEL=gpt-5.6-luna
OPENAI_API_TIMEOUT_MS=30000
# Optional unit-economics rates. Keep 0 when current trusted pricing is unknown.
OPENAI_INPUT_COST_USD_PER_1M=0
OPENAI_OUTPUT_COST_USD_PER_1M=0

AI_NEWS_DAILY_LIMIT=3
AI_NEWS_SEARCH_DAILY_LIMIT=10
AI_NEWS_SEARCH_COOLDOWN_SECONDS=60
AI_NEWS_MAX_SOURCE_AGE_HOURS=48
AI_NEWS_MAX_ARTICLES=5
AI_NEWS_SOURCE_SELECTION_TTL_SECONDS=1800
AI_NEWS_DRAFT_TTL_SECONDS=3600
AI_NEWS_PRESET_LIMIT=3

# Scheduled Telegram draft delivery only — never automatic LinkedIn publishing
# off | live
AI_NEWS_SCHEDULE_MODE=off
# vercel_daily | external_hourly
AI_NEWS_SCHEDULE_DRIVER=vercel_daily
AI_NEWS_SCHEDULE_DAILY_HOUR_UTC=8
AI_NEWS_SCHEDULE_BATCH_SIZE=5
AI_NEWS_SCHEDULE_CLAIM_TIMEOUT_SECONDS=900
AI_NEWS_SCHEDULE_RETRY_DELAY_SECONDS=900
AI_NEWS_SCHEDULE_MAX_ATTEMPTS=3
# Used only by an external-hourly caller. Vercel daily uses CRON_SECRET.
AI_NEWS_CRON_SECRET=

# STEP053A staging acceptance — do not keep mutation ACKs enabled
STEP053A_TARGET=
STEP053A_EVIDENCE_DIR=runtime_evidence/step053a
STEP053A_ARTIFACT_SHA=
STEP053A_MUTATION_ACK=
STEP053A_DATABASE_ACK=

# STEP057 production readiness — read-only
STEP057_TARGET=
STEP057_BASE_URL=
STEP057_ARTIFACT_SHA=
STEP057_TELEGRAM_BOT_USERNAME=introdeckbot
STEP057_EVIDENCE_DIR=runtime_evidence/step057

# STEP061A production acceptance — read-only preflight + manual evidence
STEP061A_TARGET=
STEP061A_BASE_URL=
STEP061A_ARTIFACT_SHA=
STEP061A_TELEGRAM_USER_ID=
STEP061A_TELEGRAM_BOT_USERNAME=introdeckbot
STEP061A_EVIDENCE_DIR=runtime_evidence/step061a
