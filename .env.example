TELEGRAM_BOT_TOKEN=replace_me
TELEGRAM_BOT_USERNAME=rollduelbot
CRYPTO_PAY_API_TOKEN=replace_me
ADMIN_IDS=123456789

# Database
DATABASE_BACKEND=postgres
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/roll_duel
DATABASE_FILE=dice_game.db

# Delivery/runtime
TELEGRAM_DELIVERY_MODE=webhook
APP_BASE_URL=https://your-domain.example
APP_HOST=0.0.0.0
PORT=8080
TELEGRAM_WEBHOOK_PATH=/webhook/telegram
CRYPTOPAY_WEBHOOK_PATH=/webhook/cryptopay
TELEGRAM_WEBHOOK_SECRET=replace_me_strong_secret
ENABLE_INVOICE_POLLING=0
# Legacy fallback only. Keep disabled in the normal webhook baseline.

# Classic bot surface
SUPPORT_TELEGRAM_HANDLE=@rollduelbot
SUPPORT_TON_ADDRESS=
# Legacy DurovCube handles are ignored at runtime and fall back to @rollduelbot.

# Runtime tuning
WAITING_DUEL_TIMEOUT_SECONDS=900
ACTIVE_DUEL_TIMEOUT_SECONDS=300
RECONCILIATION_INTERVAL_SECONDS=20
ADMIN_BROADCAST_TICK_SECONDS=15
ADMIN_BROADCAST_BATCH_SIZE=25
ADMIN_BROADCAST_MAX_RETRIES=3
LOG_LEVEL=INFO

# Operator web UI
ADMIN_WEB_USERNAME=admin
ADMIN_WEB_PASSWORD=replace_me
ADMIN_WEB_PREFIX=/admin

# Product switches
# Optional at boot; defaults are seeded into platform_settings

# Mini App (frozen / dormant by default)
MINIAPP_RUNTIME_ENABLED=0
MINIAPP_PREFIX=/app
MINIAPP_API_PREFIX=/api/miniapp
MINIAPP_INIT_MAX_AGE_SECONDS=86400
MINIAPP_SESSION_TTL_SECONDS=86400
MINIAPP_SMOKE_CAPTURE_ENABLED=1

# STEP053 contact contract / fair-use controls
PRO_OUTREACH_DAILY_LIMIT=10
CONTACT_REQUEST_RETRY_COOLDOWN_DAYS=30
PAYMENT_CHECKOUT_AUTH_TTL_MINUTES=30
PAYMENT_CHECKOUT_RETRY_LOCK_SECONDS=1800

# Optional runtime artifact fallback when the platform does not expose a Git commit SHA
RELEASE_ARTIFACT_SHA=

# STEP053A staging runtime acceptance (never set mutation ACKs permanently)
STEP053A_TARGET=
STEP053A_EVIDENCE_DIR=runtime_evidence/step053a
STEP053A_ARTIFACT_SHA=
STEP053A_MUTATION_ACK=
STEP053A_DATABASE_ACK=

# STEP057 production-safe readiness gate (read-only; never stores secrets in evidence)
STEP057_TARGET=
STEP057_BASE_URL=
STEP057_ARTIFACT_SHA=
STEP057_TELEGRAM_BOT_USERNAME=introdeckbot
STEP057_EVIDENCE_DIR=runtime_evidence/step057

# STEP058A Verified on LinkedIn Development integration
# Keep off until migration 028 is applied and LinkedIn app admins are ready to test.
LINKEDIN_VERIFIED_MODE=off
# Development/Lite category-only API scopes. Keep separate from base OIDC scopes.
LINKEDIN_VERIFIED_SCOPES=r_profile_basicinfo r_verify_details
# LinkedIn REST API header version in YYYYMM format.
LINKEDIN_VERIFIED_IDENTITY_API_VERSION=202510.03
LINKEDIN_VERIFIED_REPORT_API_VERSION=202510
LINKEDIN_VERIFIED_API_TIMEOUT_MS=8000
# Public badges remain fail-closed until Lite approval, explicit enablement, and a fresh Lite snapshot.
LINKEDIN_VERIFIED_PUBLIC_BADGES_ENABLED=0
LINKEDIN_VERIFIED_PUBLIC_BADGE_MAX_AGE_DAYS=30
