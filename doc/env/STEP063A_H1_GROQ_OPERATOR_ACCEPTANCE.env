# Requires migration 034 and GROQ_API_KEY configured only in Vercel Production.
AI_NEWS_DRAFT_MODE=operator
AI_NEWS_ROLLOUT_STAGE=operator_acceptance
AI_NEWS_SOURCE_MODE=multi_source
AI_NEWS_ENABLED_PROVIDERS=rss,hacker_news,github_releases,newsdata
AI_NEWS_GENERATOR_MODE=groq
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_DRAFT_MODEL=openai/gpt-oss-20b
GROQ_API_TIMEOUT_MS=30000
GROQ_INPUT_COST_USD_PER_1M=0
GROQ_OUTPUT_COST_USD_PER_1M=0
AI_NEWS_DAILY_LIMIT=6
AI_NEWS_SCHEDULE_MODE=off
